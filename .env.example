# ===== AuditAgentX 环境变量示例 =====
# 复制本文件为 .env 并填入真实配置。不要提交真实 API Key。

# ---- 大模型配置（OpenAI 兼容接口）----
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://api.example.com/v1
LLM_MODEL=your-model-name
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096
LLM_TIMEOUT=120
# 调用健壮性：失败重试次数与退避基数（秒）。鉴权/额度类错误不重试。
LLM_MAX_RETRIES=2
LLM_RETRY_BACKOFF=1.5
# SummaryAgent 默认使用本地规则稳定生成摘要；设置为 1 时才调用大模型润色
SUMMARY_AGENT_USE_LLM=0

# ---- 数据库 ----
DATABASE_URL=sqlite:///./data/auditagentx.db

# ---- 数据与工作目录 ----
DATA_DIR=./data
WORKSPACE_DIR=./data/projects

# ---- 静态扫描工具开关（需在系统或 Docker 中预装）----
ENABLE_SEMGREP=true
ENABLE_BANDIT=true
ENABLE_GITLEAKS=true
ENABLE_TRIVY=false

# ---- 沙箱验证 ----
# DOCKER_HOST 留空则自动适配平台（Windows named pipe / Linux unix socket）。
# 仅在需要连接远程 Docker 时才填，例如 tcp://localhost:2375
DOCKER_HOST=
SANDBOX_TIMEOUT=60

# ---- 服务 ----
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
